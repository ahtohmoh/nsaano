# Nsaano model-provider keys. Copy this file to `.env` and fill in the keys you have.
# Keys are read by the backend proxy only — they are never sent to the browser.

# Anthropic (Claude). https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI (GPT). https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini. https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: port the studio runs on (default 3000)
PORT=3000
